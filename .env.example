NODE_ENV=production
PORT=5000

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/soltech-trade?retryWrites=true&w=majority

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Go to Firebase Console > Project Settings > Service Accounts > Generate new private key
# Then base64-encode the downloaded JSON:  base64 -w0 serviceAccount.json
FIREBASE_SERVICE_ACCOUNT=<base64-encoded-service-account-json>

# ── Helius RPC ────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key

# ── Birdeye (charts + token data) ─────────────────────────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://soltechtrade.netlify.app

# ── Monetization ─────────────────────────────────────────────────────────────
# Your Phantom wallet address (receives SOL subscription payments)
PLATFORM_WALLET=YOUR_PHANTOM_WALLET_ADDRESS

# Monthly subscription price in SOL
SUBSCRIPTION_PRICE_SOL=0.05
